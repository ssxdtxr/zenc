generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  // Free-form plan slug (e.g. "beta", later "free"/"pro"/...) — drives the
  // daily AI call cap in lib/ai-usage.ts. String, not an enum, so adding a
  // plan later doesn't need a migration to alter a Postgres enum type.
  plan         String         @default("beta")
  createdAt    DateTime       @default(now())
  topics       Topic[]
  aiUsage      AiUsageDaily[]
}

// Per-user daily counter for Anthropic API calls — enforces the hard usage cap.
model AiUsageDaily {
  id     String   @id @default(cuid())
  userId String
  date   DateTime // truncated to UTC midnight
  count  Int      @default(0)
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// Personal invite links gating registration during the closed beta.
// Created out-of-band (scripts/create-invite.ts), redeemed once at signup.
model InviteToken {
  id           String    @id @default(cuid())
  token        String    @unique
  note         String?
  createdAt    DateTime  @default(now())
  usedAt       DateTime?
  usedByUserId String?
}

model Topic {
  id            String          @id @default(cuid())
  userId        String
  name          String
  createdAt     DateTime        @default(now())
  lastSessionAt DateTime?
  overallLevel  String?
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions      Session[]
  subtopics     TopicSubtopic[]
}

model TopicSubtopic {
  id             String    @id @default(cuid())
  topicId        String
  name           String
  status         String
  recommendation String    @db.Text
  definitions    Json      @default("[]")
  // Names of other subtopics (within the same topic) that should be understood
  // first — drives the dependency graph on the topic page. String[] of names,
  // not ids, since names are the stable identity subtopics are keyed on.
  prerequisites  Json      @default("[]")
  nextReviewAt   DateTime?
  topic          Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, name])
}

model Session {
  id            String   @id @default(cuid())
  topicId       String
  date          DateTime @default(now())
  score         Int
  total         Int
  overallLevel  String
  summary       String   @db.Text
  strengths     Json
  toStudyMore   Json
  toStudyDeeper Json
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

// Global theory cache — one entry per (topicName + subtopicName + level)
// Saves Anthropic API calls: generate once, reuse forever
model TheoryCache {
  id           String   @id @default(cuid())
  cacheKey     String   @unique
  topicName    String
  subtopicName String
  userLevel    String
  content      Json
  createdAt    DateTime @default(now())

  @@index([topicName, subtopicName, userLevel])
}
